//
//  Cmajor_FMOD.cpp
//

#include <stdio.h>
#include <string.h>

#if defined(__EMSCRIPTEN__)
#include <emscripten.h>
#endif

#include "CmajorWrapper.hpp"
#include "cmajor_patch.cpp"

using CmajorProcessor = @CMAJOR_CLASS_NAME@;
using WrapperType = CmajorWrapper<CmajorProcessor>;

#define MAX_CMAJOR_PARAMETERS 1000

extern "C" {
#if defined(__EMSCRIPTEN__)
    EMSCRIPTEN_KEEPALIVE
    F_EXPORT FMOD_DSP_DESCRIPTION* F_CALL @PLUGIN_NAME@_GetDSPDescription();
#else
    F_EXPORT FMOD_DSP_DESCRIPTION* F_CALL FMODGetDSPDescription();
#endif
}

FMOD_RESULT F_CALLBACK FMOD_CMAJOR_@PLUGIN_NAME@_dspcreate (FMOD_DSP_STATE *dsp_state);
FMOD_RESULT F_CALLBACK FMOD_CMAJOR_@PLUGIN_NAME@_dsprelease (FMOD_DSP_STATE *dsp_state);
FMOD_RESULT F_CALLBACK FMOD_CMAJOR_@PLUGIN_NAME@_dspreset (FMOD_DSP_STATE *dsp_state);
FMOD_RESULT F_CALLBACK FMOD_CMAJOR_@PLUGIN_NAME@_dspprocess (FMOD_DSP_STATE *dsp_state, unsigned int length, const FMOD_DSP_BUFFER_ARRAY *inbufferarray, FMOD_DSP_BUFFER_ARRAY *outbufferarray, FMOD_BOOL inputsidle, FMOD_DSP_PROCESS_OPERATION op);
FMOD_RESULT F_CALLBACK FMOD_CMAJOR_@PLUGIN_NAME@_dspsetparamfloat (FMOD_DSP_STATE *dsp_state, int index, float value);
FMOD_RESULT F_CALLBACK FMOD_CMAJOR_@PLUGIN_NAME@_dspgetparamfloat (FMOD_DSP_STATE *dsp_state, int index, float *value, char *valuestr);

static FMOD_DSP_PARAMETER_DESC FMOD_CMAJOR_@PLUGIN_NAME@_Parameters[MAX_CMAJOR_PARAMETERS];
FMOD_DSP_PARAMETER_DESC *FMOD_CMAJOR_@PLUGIN_NAME@_DSPParam[MAX_CMAJOR_PARAMETERS] = {};

FMOD_DSP_DESCRIPTION FMOD_CMAJOR_@PLUGIN_NAME@_Desc =
{
    FMOD_PLUGIN_SDK_VERSION,
    "@PLUGIN_NAME@", //name
    0x00010000, //plugin version
    0, //inbuffer
    0, //outbuffer
    FMOD_CMAJOR_@PLUGIN_NAME@_dspcreate,
    FMOD_CMAJOR_@PLUGIN_NAME@_dsprelease,
    FMOD_CMAJOR_@PLUGIN_NAME@_dspreset,
    0,
    FMOD_CMAJOR_@PLUGIN_NAME@_dspprocess,
    0,
    MAX_CMAJOR_PARAMETERS,
    FMOD_CMAJOR_@PLUGIN_NAME@_DSPParam,
    FMOD_CMAJOR_@PLUGIN_NAME@_dspsetparamfloat, //setfloat
    0, //setint
    0, //setbool
    0, //setdata
    FMOD_CMAJOR_@PLUGIN_NAME@_dspgetparamfloat, //getfloat
    0, //getint
    0, //getbool
    0, //getdata
    0,
    0, //userdata
    0, //sys_register
    0, //sys_deregister
    0  //sys_mix
};

extern "C" {
#ifdef EMSCRIPTEN
    F_EXPORT FMOD_DSP_DESCRIPTION* F_CALL @PLUGIN_NAME@_GetDSPDescription()
#else
    F_EXPORT FMOD_DSP_DESCRIPTION* F_CALL FMODGetDSPDescription()
#endif
{
    // Create a temporary wrapper to parse parameters
    WrapperType tempWrapper;
    tempWrapper.Init(44100.0);
    
    int finalParameters = 0;
    for (size_t i = 0; i < tempWrapper.parameters.size(); ++i)
    {
        const auto& param = tempWrapper.parameters[i];
        FMOD_CMAJOR_@PLUGIN_NAME@_DSPParam[finalParameters] = &FMOD_CMAJOR_@PLUGIN_NAME@_Parameters[finalParameters];
        
        FMOD_DSP_INIT_PARAMDESC_FLOAT(FMOD_CMAJOR_@PLUGIN_NAME@_Parameters[finalParameters], 
                                      param.name.c_str(), param.unit.c_str(), "Cmajor param", 
                                      param.min, param.max, param.init);
        FMOD_CMAJOR_@PLUGIN_NAME@_Parameters[finalParameters].floatdesc.mapping.type = FMOD_DSP_PARAMETER_FLOAT_MAPPING_TYPE_LINEAR;
        finalParameters++;
    }
    
    if (tempWrapper.numInputChannels > 0)
        FMOD_CMAJOR_@PLUGIN_NAME@_Desc.numinputbuffers = 1;
    
    if (tempWrapper.numOutputChannels > 0)
        FMOD_CMAJOR_@PLUGIN_NAME@_Desc.numoutputbuffers = 1;
    
    FMOD_CMAJOR_@PLUGIN_NAME@_Desc.numparameters = finalParameters;
    
    return &FMOD_CMAJOR_@PLUGIN_NAME@_Desc;
}
}

FMOD_RESULT F_CALLBACK FMOD_CMAJOR_@PLUGIN_NAME@_dspcreate(FMOD_DSP_STATE *dsp_state)
{
    dsp_state->plugindata = (WrapperType *)FMOD_DSP_ALLOC(dsp_state, sizeof(WrapperType));
    if (!dsp_state->plugindata)
        return FMOD_ERR_MEMORY;
    
    WrapperType *state = new (dsp_state->plugindata) WrapperType();
    
    int sampleRate = 44100;
    FMOD_DSP_GETSAMPLERATE(dsp_state, &sampleRate);
    
    state->Init(sampleRate);
    
    return FMOD_OK;
}

FMOD_RESULT F_CALLBACK FMOD_CMAJOR_@PLUGIN_NAME@_dsprelease(FMOD_DSP_STATE *dsp_state)
{
    WrapperType *state = (WrapperType *)dsp_state->plugindata;
    
    if (state) {
        state->~WrapperType();
    }
    
    FMOD_DSP_FREE(dsp_state, state);
    return FMOD_OK;
}

FMOD_RESULT F_CALLBACK FMOD_CMAJOR_@PLUGIN_NAME@_dspprocess(FMOD_DSP_STATE *dsp_state, unsigned int length, const FMOD_DSP_BUFFER_ARRAY *inbufferarray, FMOD_DSP_BUFFER_ARRAY *outbufferarray, FMOD_BOOL inputsidle, FMOD_DSP_PROCESS_OPERATION op)
{
    WrapperType *state = (WrapperType *)dsp_state->plugindata;
    
    if(op == FMOD_DSP_PROCESS_QUERY)
    {
        if (!outbufferarray)
            return FMOD_ERR_DSP_DONTPROCESS;
        
        if (state->multiChannelExpandable && inbufferarray && inbufferarray->numbuffers > 0)
        {
            auto chans = inbufferarray->buffernumchannels[0];
            outbufferarray->buffernumchannels[0] = chans;
            
            switch(chans)
            {
                case 1: outbufferarray->speakermode = FMOD_SPEAKERMODE_MONO; break;
                case 2: outbufferarray->speakermode = FMOD_SPEAKERMODE_STEREO; break;
                case 4: outbufferarray->speakermode = FMOD_SPEAKERMODE_QUAD; break;
                case 5: outbufferarray->speakermode = FMOD_SPEAKERMODE_SURROUND; break;
                case 6: outbufferarray->speakermode = FMOD_SPEAKERMODE_5POINT1; break;
                case 8: outbufferarray->speakermode = FMOD_SPEAKERMODE_7POINT1; break;
                default: outbufferarray->speakermode = FMOD_SPEAKERMODE_DEFAULT; break;
            }
        }
        else
        {
            if (state->numInputChannels > 1 && inbufferarray)
            {
                if (inbufferarray->buffernumchannels[0] != state->numInputChannels)
                    return FMOD_ERR_DSP_DONTPROCESS;
            }
            
            outbufferarray->buffernumchannels[0] = state->numOutputChannels;
            
            switch(state->numOutputChannels)
            {
                case 1: outbufferarray->speakermode = FMOD_SPEAKERMODE_MONO; break;
                case 2: outbufferarray->speakermode = FMOD_SPEAKERMODE_STEREO; break;
                case 4: outbufferarray->speakermode = FMOD_SPEAKERMODE_QUAD; break;
                case 5: outbufferarray->speakermode = FMOD_SPEAKERMODE_SURROUND; break;
                case 6: outbufferarray->speakermode = FMOD_SPEAKERMODE_5POINT1; break;
                case 8: outbufferarray->speakermode = FMOD_SPEAKERMODE_7POINT1; break;
                default: outbufferarray->speakermode = FMOD_SPEAKERMODE_DEFAULT; break;
            }
        }
        
        return FMOD_OK;
    }

    const float* inBuffer = nullptr;
    int inChannels = 0;
    if (inbufferarray && inbufferarray->numbuffers > 0) {
        inBuffer = inbufferarray[0].buffers[0];
        inChannels = inbufferarray->buffernumchannels[0];
    }
        
    float* outBuffer = nullptr;
    int outChannels = 0;
    if (outbufferarray && outbufferarray->numbuffers > 0) {
        outBuffer = outbufferarray[0].buffers[0];
        outChannels = outbufferarray->buffernumchannels[0];
    }
        
    state->Process(inBuffer, outBuffer, length, inChannels, outChannels);
    
    return FMOD_OK;
}

FMOD_RESULT F_CALLBACK FMOD_CMAJOR_@PLUGIN_NAME@_dspreset(FMOD_DSP_STATE *dsp_state)
{
    WrapperType *state = (WrapperType *)dsp_state->plugindata;
    if (state)
        state->Reset();
    return FMOD_OK;
}

FMOD_RESULT F_CALLBACK FMOD_CMAJOR_@PLUGIN_NAME@_dspsetparamfloat(FMOD_DSP_STATE *dsp_state, int index, float value)
{
    WrapperType *state = (WrapperType *)dsp_state->plugindata;
    if (state) {
        state->SetParameterValue(index, value);
        return FMOD_OK;
    }
    return FMOD_ERR_INVALID_PARAM;
}

FMOD_RESULT F_CALLBACK FMOD_CMAJOR_@PLUGIN_NAME@_dspgetparamfloat(FMOD_DSP_STATE *dsp_state, int index, float *value, char *valuestr)
{
    WrapperType *state = (WrapperType *)dsp_state->plugindata;
    if (state) {
        *value = state->GetParameterValue(index);
        if (valuestr)
            snprintf(valuestr, FMOD_DSP_GETPARAM_VALUESTR_LENGTH, "%.2f", *value);
        return FMOD_OK;
    }
    return FMOD_ERR_INVALID_PARAM;
}
