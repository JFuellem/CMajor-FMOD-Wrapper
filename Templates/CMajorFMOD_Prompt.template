## F) REFERENCE TEMPLATE -- FMOD Generator (Triggered Synth)

processor FmodSynth
{
    output stream float out;

    // FMOD handles triggers via float parameters instead of MIDI
    input event float paramPitch [[ name: "Pitch", min: 20.0, max: 2000.0, init: 440.0, unit: "Hz" ]];
    input event float paramGate  [[ name: "Gate",  min: 0.0,  max: 1.0,    init: 0.0 ]];
    input event float paramDecay [[ name: "Decay", min: 50.0, max: 4000.0, init: 400.0, unit: "ms" ]];

    float pitch = 440.0f;
    float gate  = 0.0f;
    float decay = 400.0f;

    event paramPitch (float v) { pitch = v; }
    event paramGate  (float v) { gate = v; }
    event paramDecay (float v) { decay = v; }

    float64 phase = 0.0;
    float env = 0.0f;

    void main()
    {
        loop
        {
            let dt = float(processor.period);

            // Simple envelope based on gate parameter
            if (gate > 0.5f)
                env += (1.0f - env) * (dt / 0.01f); // 10ms attack
            else
                env *= (1.0f - dt / (decay * 0.001f)); // Release based on decay param

            // Sawtooth oscillator
            phase += float64(pitch) * processor.period;
            if (phase >= 1.0) phase -= 1.0;
            float saw = float(phase * 2.0 - 1.0);

            // Soft clip
            let driven = (saw * env) * 2.0f;
            float clipped = driven / (1.0f + abs(driven));

            out <- clipped * 0.2f;
            advance();
        }
    }
}

